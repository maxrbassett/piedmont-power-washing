---
import * as site from '@data/site';
import BeforeAfter from '@components/BeforeAfter.astro';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

// Resolve the comparator photos from src/assets by basename.
const modules = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/*.{jpg,jpeg,png,webp}',
  { eager: true },
);
const img = (name: string) => modules[`/src/assets/${name}.jpg`].default;

const pairs = site.comparePairs.map((p) => ({
  ...p,
  beforeImg: img(p.before),
  afterImg: img(p.after),
}));
---

<section class="hero" id="top">
  <div class="wrap hero-grid">
    <div class="hero-copy">
      <p class="eyebrow">Charlotte, NC &amp; SC</p>
      <h1 class="hero-name">{site.tagline}</h1>
      <p class="hero-sub">{site.heroSubhead}</p>
      <div class="hero-cta">
        <a class="btn btn-primary" href="#contact">Get a Free Estimate</a>
        <a class="btn btn-outline" href={`tel:${site.phoneTel}`}>
          <span aria-hidden="true">📞</span> Call {site.phone}
        </a>
      </div>
    </div>

    <div class="hero-compare">
      <div class="ba-slides" data-ba-group>
        {pairs.map((p, i) => (
          <div class="ba-slide" data-slide={i} hidden={i !== 0}>
            <BeforeAfter
              beforeImg={p.beforeImg}
              afterImg={p.afterImg}
              beforeAlt={p.beforeAlt}
              afterAlt={p.afterAlt}
              eager={i === 0}
              sizes="(min-width: 900px) 46vw, 92vw"
              aspect="4 / 3"
            />
          </div>
        ))}
      </div>

      <div class="ba-controls">
        {pairs.length > 1 && (
          <div class="ba-thumbs" role="tablist" aria-label="Choose a before-and-after example">
            {pairs.map((p, i) => (
              <button
                type="button"
                class:list={['ba-thumb', { 'is-active': i === 0 }]}
                data-slide-btn={i}
                role="tab"
                aria-selected={i === 0 ? 'true' : 'false'}
                aria-label={`Show before and after: ${p.label}`}
              >
                <Image src={p.afterImg} alt="" widths={[96, 160]} sizes="72px" loading="eager" />
              </button>
            ))}
          </div>
        )}
        <a class="ba-more" href="#work">See more of our work <span aria-hidden="true">↓</span></a>
      </div>
      <p class="ba-hint"><span aria-hidden="true">↔</span> {site.compareIntro}</p>
    </div>
  </div>
</section>

<script>
  // Switch which before/after pair the hero shows.
  const group = document.querySelector('[data-ba-group]');
  const tabs = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-slide-btn]'));
  if (group && tabs.length) {
    const slides = Array.from(group.querySelectorAll<HTMLElement>('[data-slide]'));
    tabs.forEach((btn) => {
      btn.addEventListener('click', () => {
        const idx = Number(btn.getAttribute('data-slide-btn'));
        slides.forEach((s) => { s.hidden = Number(s.getAttribute('data-slide')) !== idx; });
        tabs.forEach((b) => {
          const active = b === btn;
          b.classList.toggle('is-active', active);
          b.setAttribute('aria-selected', String(active));
        });
      });
    });
  }
</script>

<style>
  .hero {
    background:
      radial-gradient(1200px 500px at 85% -10%, var(--color-sky-tint), transparent 60%),
      var(--color-white);
    padding-block: clamp(2.5rem, 6vw, 4.5rem);
  }
  .hero-grid {
    display: grid;
    gap: clamp(2rem, 5vw, 3.5rem);
    grid-template-columns: 1fr;
    align-items: center;
  }
  @media (min-width: 900px) {
    .hero-grid { grid-template-columns: 1fr 1fr; }
  }

  .hero-name {
    font-weight: 800;
    font-size: clamp(2.2rem, 5vw, 3.6rem);
    letter-spacing: -0.02em;
    margin: 0 0 0.9rem;
    max-width: 16ch;
  }
  .hero-sub {
    font-size: 1.12rem;
    max-width: 50ch;
    margin: 0 0 1.6rem;
    color: var(--color-slate);
  }
  .hero-cta { display: flex; flex-wrap: wrap; gap: 0.85rem; }

  .ba-controls {
    margin-top: 0.9rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem 1rem;
  }
  .ba-thumbs { display: flex; gap: 0.5rem; }
  .ba-thumb {
    width: 56px;
    height: 56px;
    padding: 0;
    border-radius: 10px;
    border: 2px solid var(--color-line);
    background: var(--color-cloud-2);
    overflow: hidden;
    cursor: pointer;
    line-height: 0;
    transition: border-color 0.12s ease, transform 0.12s ease;
  }
  .ba-thumb :global(img) { width: 100%; height: 100%; object-fit: cover; }
  .ba-thumb:hover { transform: translateY(-2px); border-color: var(--color-sky); }
  .ba-thumb.is-active { border-color: var(--color-blue); }

  .ba-more {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--color-blue);
    text-decoration: none;
    white-space: nowrap;
  }
  .ba-more span { transition: transform 0.12s ease; display: inline-block; }
  .ba-more:hover span { transform: translateY(3px); }

  .ba-hint {
    margin-top: 0.6rem;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.84rem;
    color: var(--color-slate-soft);
  }
</style>
