---
import * as site from '@data/site';
---

<div class="callbar" aria-label="Quick actions">
  <a class="callbar-btn primary" href={`tel:${site.phoneTel}`}>
    <span aria-hidden="true">📞</span> Call
  </a>
  <a class="callbar-btn" href="#contact">
    <span aria-hidden="true">✉️</span> Free Estimate
  </a>
  <a class="callbar-btn" href={site.directionsUrl} target="_blank" rel="noopener">
    <span aria-hidden="true">📍</span> Directions
  </a>
</div>

<style>
  .callbar {
    position: fixed;
    left: 0; right: 0; bottom: 0;
    z-index: 90;
    display: grid;
    grid-template-columns: 1fr 1.2fr 1fr;
    gap: 1px;
    background: var(--color-line);
    border-top: 1px solid var(--color-line);
    box-shadow: 0 -6px 20px rgba(12, 44, 74, 0.18);
    padding-bottom: env(safe-area-inset-bottom);
  }
  .callbar-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    padding: 0.9rem 0.5rem;
    background: #fff;
    color: var(--color-navy);
    text-decoration: none;
    border: 0;
    cursor: pointer;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.9rem;
  }
  .callbar-btn.primary { background: var(--color-blue); color: #fff; }

  @media (min-width: 768px) { .callbar { display: none; } }
</style>
