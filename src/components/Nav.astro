---
import * as site from '@data/site';
import { Image } from 'astro:assets';
import logo from '@assets/logo.png';
---

<header class="nav" aria-label="Site header">
  <div class="wrap nav-inner">
    <a class="brand" href="#top" aria-label={`${site.longName} — home`}>
      <Image src={logo} alt={`${site.longName} logo`} widths={[160, 240, 320]} sizes="180px" loading="eager" />
    </a>

    <nav class="nav-links" aria-label="Primary">
      {site.nav.map((n) => <a href={n.href}>{n.label}</a>)}
    </nav>

    <div class="nav-actions">
      <a class="nav-call" href={`tel:${site.phoneTel}`}>
        <span aria-hidden="true">📞</span> {site.phone}
      </a>
      <a class="btn btn-primary nav-quote" href="#contact">Free Estimate</a>
    </div>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 80;
    background: color-mix(in srgb, var(--color-white) 92%, transparent);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--color-line);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    height: 68px;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    flex-shrink: 0;
  }
  .brand :global(img) {
    height: 46px;
    width: auto;
  }

  .nav-links {
    display: none;
    gap: 1.5rem;
  }
  .nav-links a {
    font-family: var(--font-display);
    letter-spacing: 0.01em;
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--color-ink);
    text-decoration: none;
  }
  .nav-links a:hover { color: var(--color-blue); }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 0.85rem;
  }
  .nav-call {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--color-navy);
    text-decoration: none;
    white-space: nowrap;
  }
  .nav-call:hover { color: var(--color-blue); }
  .nav-quote { padding: 0.55rem 1.1rem; font-size: 0.9rem; }

  @media (min-width: 940px) {
    .nav-links { display: inline-flex; }
  }
  /* Below the mobile call bar breakpoint, the sticky bottom bar carries the
     phone, so the inline nav phone can step aside on the tightest screens. */
  @media (max-width: 560px) {
    .nav-call { display: none; }
  }
  @media (max-width: 360px) {
    .brand :global(img) { height: 38px; }
  }
</style>
