---
import * as site from '@data/site';
import { Image } from 'astro:assets';
import areaPhoto from '@assets/about-large.jpg';
---

<section id="area" class="area" aria-labelledby="area-title">
  <div class="wrap area-grid">
    <div class="area-info">
      <p class="eyebrow">Where we work</p>
      <h2 id="area-title" class="section-title">Service area</h2>
      <p class="section-intro">{site.areaIntro}</p>

      <ul class="area-list">
        {site.serviceArea.map((town) => (
          <li>
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z" />
              <circle cx="12" cy="10" r="2.5" />
            </svg>
            <span>{town}</span>
          </li>
        ))}
      </ul>

      <p class="area-note">{site.areaNote}</p>

      <div class="area-cta">
        <a class="btn btn-primary" href="#contact">Get a Free Estimate</a>
        <a class="btn btn-outline" href={`tel:${site.phoneTel}`}>
          <span aria-hidden="true">📞</span> {site.phone}
        </a>
      </div>
    </div>

    <figure class="area-photo">
      <Image
        src={areaPhoto}
        alt="A clean home exterior in the Charlotte NC/SC area served by Piedmont Power Washing"
        widths={[480, 720, 1000]}
        sizes="(min-width: 900px) 48vw, 100vw"
        loading="lazy"
      />
    </figure>
  </div>
</section>

<style>
  .area { background: var(--color-white); }
  .area-grid {
    display: grid;
    gap: 2.5rem;
    grid-template-columns: 1fr;
    align-items: center;
  }
  @media (min-width: 900px) { .area-grid { grid-template-columns: 1.05fr 0.95fr; gap: 3rem; } }

  .area-list {
    list-style: none;
    margin: 0 0 1.5rem;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.55rem 1rem;
  }
  @media (min-width: 520px) { .area-list { grid-template-columns: repeat(3, 1fr); } }
  @media (min-width: 900px) { .area-list { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1040px) { .area-list { grid-template-columns: repeat(3, 1fr); } }

  .area-list li {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    color: var(--color-ink);
    font-weight: 500;
    font-size: 0.96rem;
  }
  .area-list svg { color: var(--color-sky-mid); flex-shrink: 0; }

  .area-note {
    color: var(--color-slate);
    font-style: italic;
    border-left: 3px solid var(--color-sky);
    padding-left: 0.9rem;
    margin-bottom: 1.5rem;
  }

  .area-cta { display: flex; flex-wrap: wrap; gap: 0.85rem; }

  .area-photo {
    margin: 0;
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid var(--color-line);
    box-shadow: 0 18px 40px rgba(12, 44, 74, 0.14);
  }
  .area-photo :global(img) {
    width: 100%;
    height: 100%;
    max-height: 460px;
    object-fit: cover;
    display: block;
  }
</style>
