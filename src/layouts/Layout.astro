---
import '@styles/global.css';
import * as site from '@data/site';

const ogImage = Astro.site ? new URL('/og.jpg', Astro.site).href : '/og.jpg';

const localBusiness = {
  '@context': 'https://schema.org',
  '@type': 'HomeAndConstructionBusiness',
  '@id': Astro.site?.href,
  name: site.longName,
  alternateName: site.name,
  description: site.seo.description,
  image: ogImage,
  telephone: site.phone,
  email: site.email,
  url: Astro.site?.href,
  priceRange: '$$',
  sameAs: [site.links.facebook],
  areaServed: site.serviceArea.map((a) => ({ '@type': 'Place', name: a })),
  address: {
    '@type': 'PostalAddress',
    streetAddress: site.address.street,
    addressLocality: site.address.city,
    addressRegion: site.address.state,
    postalCode: site.address.zip,
    addressCountry: 'US',
  },
  hasMap: site.mapsUrl,
  knowsAbout: site.services.map((s) => s.title),
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{site.seo.title}</title>
    <meta name="description" content={site.seo.description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@600;700;800&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <meta property="og:type" content="business.business" />
    <meta property="og:title" content={site.seo.title} />
    <meta property="og:description" content={site.seo.description} />
    <meta property="og:image" content={ogImage} />
    {Astro.site && <meta property="og:url" content={Astro.site.href} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={site.seo.title} />
    <meta name="twitter:description" content={site.seo.description} />
    <meta name="twitter:image" content={ogImage} />

    <meta name="theme-color" content="#0e5fa8" />
    <script type="application/ld+json" set:html={JSON.stringify(localBusiness)} />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <p class="test-banner" role="status">
      ⚠️ This site is for testing purposes only.
    </p>
    <slot />
  </body>
</html>

<style>
  .test-banner {
    margin: 0;
    text-align: center;
    background: var(--color-navy);
    color: #fff;
    font-family: var(--font-display);
    letter-spacing: 0.04em;
    font-weight: 600;
    font-size: 0.8rem;
    line-height: 1.3;
    padding: 0.5rem 1rem;
  }
</style>
